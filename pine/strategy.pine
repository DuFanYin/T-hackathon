//@version=5
strategy("Strat1", overlay=true, initial_capital=100000, pyramiding=0)


//====================================================================
// Inputs
//====================================================================
pivotLen = input.int(3,  "Pivot Strength (bars left/right)", minval=1)
rr       = input.float(2.0, "Risk : Reward", minval=0.5)
useLimit = input.bool(true, "Use LIMIT entry?")
fillBars = input.int(2,  "Limit must fill within next N candles", minval=1)


atrLen   = input.int(14, "ATR Length", minval=1)
atrValue = ta.atr(atrLen)


// Visual/debug toggles
showDebugMarks = input.bool(true, "Show debug rejection marks?")


//====================================================================
// Support (pivot low) tracking
//====================================================================
pivotLow = ta.pivotlow(low, pivotLen, pivotLen)


var line  supLine   = na
var float supPrice  = na
var int   hitCount  = 0
var float hit1Low   = na  // store H1 low for H2 higher-low filter


// Limit order timeout tracking
var bool limitPending = false
var int  limitBar     = na


if not na(pivotLow)
    if not na(supLine)
        line.delete(supLine)
    supPrice := pivotLow
    supLine  := line.new(bar_index - pivotLen, supPrice, bar_index, supPrice, extend=extend.right, color=color.new(color.green, 0), width=2)
    hitCount := 0
    hit1Low  := na


//====================================================================
// Helpers: strict 3-bearish sequence before EXE candle
//
// Let EXE be current bar (index 0).
// Define:
//   B1 = bar [1]  (most recent before EXE)
//   B2 = bar [2]
//   B3 = bar [3]  (oldest)
//
// Rules:
//  - For ALL B1,B2,B3:
//      1) close < open
//      2) close <= midpoint ( (high+low)/2 )
//
//  - For B2 and B1 (i.e., "2nd and 3rd bearish"):
//      a) close must be lower than LOW of previous candle:
//          close[2] < low[3]
//          close[1] < low[2]
//      b) high must NOT be higher than HIGH of previous candle:
//          high[2] <= high[3]
//          high[1] <= high[2]
//====================================================================
bCloseLowerHalf(i) =>
    close[i] <= (high[i] + low[i]) / 2.0


bBear(i) =>
    close[i] < open[i]


prev3BearishStrict =
     bBear(1) and bBear(2) and bBear(3) and
     bCloseLowerHalf(1) and bCloseLowerHalf(2) and bCloseLowerHalf(3) and
     (close[2] < low[3]) and (high[2] <= high[3]) and
     (close[1] < low[2]) and (high[1] <= high[2])


//====================================================================
// Hit detection (H1 / H2)
//====================================================================
hitSupport = not na(supPrice) and low <= supPrice


//====================================================================
// EXE (H1/H2) candle rules
//  - close in top 1/3 of EXE range
//  - close strictly above support: close > supPrice
//  - close <= open[1] (cannot be more than previous candle open)
//  - entry = midpoint of EXE candle
//  - stop  = low - mintick
//  - risk  = entry - stop must be STRICTLY < ATR
//  - for H2 only: low(H2) <= low(H1)
//====================================================================
rng = high - low
closeTopThird = rng > 0 ? close >= (low + rng * (2.0/3.0)) : false


closeAboveSupport = not na(supPrice) and close > supPrice
closeNotAbovePrevOpen = close <= open[1]


// Entry now = midpoint of entire candle
entryPrice  = (high + low) / 2.0
stopPrice   = low - syminfo.mintick
risk        = entryPrice - stopPrice
targetPrice = entryPrice + rr * risk


riskTooBig = risk >= atrValue  // STRICT: must be risk < ATR to pass


//====================================================================
// Validation pipeline for H1 then H2
//====================================================================
var bool signal = false
signal := false


// Debug reason flags (for plotshapes)
var bool rej_B3  = false
var bool rej_T3  = false
var bool rej_CS  = false
var bool rej_PO  = false
var bool rej_ATR = false
var bool rej_HL  = false
rej_B3 := false
rej_T3 := false
rej_CS := false
rej_PO := false
rej_ATR := false
rej_HL := false


if hitSupport and strategy.position_size == 0
    hitCount += 1


    // Store H1 low the moment H1 happens (even if H1 fails)
    if hitCount == 1
        hit1Low := low


    // Common gate checks for this hit candle (H1 or H2)
    okBear = prev3BearishStrict
    okT3   = closeTopThird
    okCS   = closeAboveSupport
    okPO   = closeNotAbovePrevOpen
    okATR  = not riskTooBig


    // If any fail, set debug flags
    rej_B3  := not okBear
    rej_T3  := okBear and not okT3
    rej_CS  := okBear and okT3 and not okCS
    rej_PO  := okBear and okT3 and okCS and not okPO
    rej_ATR := okBear and okT3 and okCS and okPO and not okATR


    // Additional H2-only: higher-low rejection
    higherLowFail = (hitCount == 2) and (not na(hit1Low)) and (low > hit1Low)
    rej_HL := (hitCount == 2) and okBear and okT3 and okCS and okPO and okATR and higherLowFail


    // Decide entry
    if hitCount == 1
        // H1 passes only if ALL are true
        if okBear and okT3 and okCS and okPO and okATR
            signal := true
        // else wait for H2


    else if hitCount == 2 and not signal
        // H2 passes only if ALL are true + NOT higherLowFail
        if okBear and okT3 and okCS and okPO and okATR and not higherLowFail
            signal := true
        else
            // H2 failed => skip this support entirely
            if not na(supLine)
                line.delete(supLine)
            supLine := na
            supPrice := na
            hitCount := 0
            hit1Low  := na


//====================================================================
// Execute trade (if signal)
//====================================================================
if signal and strategy.position_size == 0
    strategy.cancel("Long")


    if useLimit
        strategy.entry("Long", strategy.long, limit=entryPrice)
        limitPending := true
        limitBar := bar_index
    else
        strategy.entry("Long", strategy.long)
        limitPending := false
        limitBar := na


    strategy.exit("Exit", "Long", stop=stopPrice, limit=targetPrice)


//====================================================================
// Limit fill timeout
// signal at bar N -> allow fills on N+1..N+fillBars -> cancel at N+(fillBars+1)
//====================================================================
if strategy.position_size > 0
    limitPending := false
    limitBar := na


if useLimit and limitPending and strategy.position_size == 0 and not na(limitBar)
    if bar_index - limitBar >= (fillBars + 1)
        strategy.cancel("Long")
        limitPending := false
        limitBar := na


//====================================================================
// Visuals & Debug
//====================================================================
barcolor(signal ? color.new(color.lime, 0) : na)


// Signal markers
plotshape(signal and hitCount == 1, title="Signal H1", style=shape.triangleup, color=color.new(color.lime, 0), size=size.tiny, text="H1")
plotshape(signal and hitCount == 2, title="Signal H2", style=shape.triangleup, color=color.new(color.aqua, 0), size=size.tiny, text="H2")


// Rejection reason marks (only on hit candles)
// if showDebugMarks
//     plotshape(hitSupport and strategy.position_size == 0 and rej_B3,  title="Reject: Prev3 strict bearish failed", style=shape.xcross, color=color.new(color.yellow, 0),  size=size.tiny, text="B3")
//     plotshape(hitSupport and strategy.position_size == 0 and rej_T3,  title="Reject: Not top 1/3",               style=shape.xcross, color=color.new(color.gray, 0),    size=size.tiny, text="T3")
//     plotshape(hitSupport and strategy.position_size == 0 and rej_CS,  title="Reject: Close<=Support",            style=shape.xcross, color=color.new(color.fuchsia, 0), size=size.tiny, text="CS")
//     plotshape(hitSupport and strategy.position_size == 0 and rej_PO,  title="Reject: Close>PrevOpen",            style=shape.xcross, color=color.new(color.blue, 0),    size=size.tiny, text="PO")
//     plotshape(hitSupport and strategy.position_size == 0 and rej_ATR, title="Reject: Risk>=ATR",                 style=shape.xcross, color=color.new(color.red, 0),     size=size.tiny, text="ATR")
//     plotshape(hitSupport and strategy.position_size == 0 and rej_HL,  title="Reject H2: Higher Low (H2>H1)",     style=shape.xcross, color=color.new(color.orange, 0),  size=size.tiny, text="HL")


