General_Portfolio_Testing_API_KEY='your_api_key'
General_Portfolio_Testing_API_SECRET='your_api_secret'

Competition_API_KEY='your_api_key'
Competition_API_SECRET='your_api_secret'

ENVIRONMENT='local'  # or 'cloud'

# Control API (backend → frontend)
CONTROL_HOST=0.0.0.0
CONTROL_PORT=8000
# Comma-separated list, NO extra quotes
CONTROL_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app

CONTROL_ADMIN_TOKEN='your_admin_token'